{
  "name": "tailwind-pattern-audit",
  "version": "0.1.0",
  "description": "Find repeated Tailwind class patterns in JavaScript and TypeScript projects.",
  "type": "module",
  "license": "MIT",
  "author": "Naum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tijlio/tailwind-pattern-audit.git"
  },
  "bugs": {
    "url": "https://github.com/Tijlio/tailwind-pattern-audit/issues"
  },
  "homepage": "https://github.com/Tijlio/tailwind-pattern-audit#readme",
  "keywords": [
    "tailwind",
    "tailwindcss",
    "audit",
    "className",
    "cli",
    "react",
    "nextjs",
    "shadcn-ui"
  ],
  "packageManager": "pnpm@10.33.0",
  "sideEffects": false,
  "bin": {
    "tailwind-pattern-audit": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.3.1",
    "ajv": "^8.20.0",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
