{
  "name": "tailwind-pattern-audit-vscode",
  "displayName": "Tailwind Pattern Audit",
  "description": "View Tailwind Pattern Audit duplicate groups and diagnostics in VS Code.",
  "version": "0.0.0",
  "publisher": "tijlio",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tijlio/tailwind-pattern-audit.git",
    "directory": "vscode-extension"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onCommand:tailwindPatternAudit.run",
    "onCommand:tailwindPatternAudit.refresh",
    "workspaceContains:tailwind-pattern-audit.config.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tailwindPatternAudit.run",
        "title": "Tailwind Pattern Audit: Run"
      },
      {
        "command": "tailwindPatternAudit.refresh",
        "title": "Tailwind Pattern Audit: Refresh"
      },
      {
        "command": "tailwindPatternAudit.openReport",
        "title": "Tailwind Pattern Audit: Open Report"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tailwindPatternAudit",
          "title": "Tailwind Pattern Audit",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "tailwindPatternAudit": [
        {
          "id": "tailwindPatternAudit.findings",
          "name": "Findings"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "tailwindPatternAudit.refresh",
          "when": "view == tailwindPatternAudit.findings",
          "group": "navigation"
        },
        {
          "command": "tailwindPatternAudit.openReport",
          "when": "view == tailwindPatternAudit.findings",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Tailwind Pattern Audit",
      "properties": {
        "tailwindPatternAudit.command": {
          "type": "string",
          "default": "",
          "description": "Optional command override for running Tailwind Pattern Audit instead of the bundled library."
        },
        "tailwindPatternAudit.args": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Arguments passed before Tailwind Pattern Audit CLI options when command override is set."
        },
        "tailwindPatternAudit.includeSimilar": {
          "type": "boolean",
          "default": true,
          "description": "Include near-duplicate class set detection when running the audit."
        }
      }
    }
  },
  "dependencies": {
    "tailwind-pattern-audit": "^1.2.1"
  }
}
